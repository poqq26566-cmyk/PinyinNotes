<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 编辑模式：原始文本输入框 -->
    <EditText
        android:id="@+id/editContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:gravity="top|start"
        android:padding="16dp"
        android:textSize="16sp"
        android:inputType="textMultiLine|textCapSentences"
        android:hint="开始输入..."
        android:importantForAutofill="no" />

    <!-- 阅读模式：渲染 Markdown 链接的 ScrollView（默认隐藏） -->
    <!-- ✅ 关键：用 id=scrollReadView 在代码里控制整个容器的可见性 -->
    <ScrollView
        android:id="@+id/scrollReadView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvReadView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:textColorLink="#1565C0"
            android:linksClickable="true"
            android:autoLink="none"
            android:textIsSelectable="true" />

    </ScrollView>

    <ImageButton
        android:id="@+id/btnToggleMode"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:background="@drawable/bg_add_button"
        android:src="@android:drawable/ic_menu_view"
        android:tint="@android:color/white"
        android:contentDescription="切换编辑/阅读模式"
        android:elevation="6dp" />

    <ImageButton
        android:id="@+id/btnChooseApp"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="76dp"
        android:background="@drawable/bg_add_button"
        android:src="@android:drawable/ic_menu_manage"
        android:tint="@android:color/white"
        android:contentDescription="选择默认打开App"
        android:elevation="6dp" />

</FrameLayout>
